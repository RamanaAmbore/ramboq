{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Litestar API",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["backend.api.app:app", "--host", "127.0.0.1", "--port", "8001", "--reload"],
            "python": "${workspaceFolder}/venv/bin/python",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "RAMBOQ_LOG_PREFIX": "api_"
            }
        }
    ]
}
