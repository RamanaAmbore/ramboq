[Unit]
Description=Streamlit App for dev.ramboq.com
After=network.target

[Service]
WorkingDirectory=/opt/ramboq_dev
ExecStart=/bin/bash -c 'source /opt/ramboq_dev/venv/bin/activate && streamlit run app.py --server.port=8503 --server.address=0.0.0.0 2>>&1 | tee -a /opt/ramboq/.log/short_error_file_dev /opt/ramboq/.log/error_file_dev'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
